{
  "name": "tunet-dashboard",
  "private": true,
  "version": "1.16.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oyvhov/tunet.git"
  },
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently \"vite\" \"node server/index.js\"",
    "server": "node server/index.js",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "postbuild": "node scripts/postbuild.js",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml,mjs,cjs,html}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml,mjs,cjs,html}\"",
    "lint": "eslint src",
    "lint:theme-colors": "node scripts/lint-theme-colors.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "i18n:check": "vitest run src/__tests__/i18n.test.js",
    "test:watch": "vitest",
    "release:prep": "node scripts/release.mjs prep",
    "release:check": "node scripts/release.mjs check",
    "release:cut": "node scripts/release.mjs cut",
    "release:publish": "node scripts/release.mjs publish",
    "release": "npm run release:check ; npm run test ; npm run build ; npm run release:publish"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "home-assistant-js-websocket": "^9.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
